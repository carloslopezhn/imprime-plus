{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Imprime+",
  "version": "1.3.7",
  "identifier": "hn.utp.imprime-plus",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Imprime+",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkzQjg5REM1NDExMTBCMUIKUldRYkN4RkJ4WjI0azBlc0U5aEFsUkEwQkNLWExpWlNDeXJDaG1YWjJKNjRLSEZueXdUTHR1MVUK",
      "endpoints": [
        "https://imprime.utp.hn/api/update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "publisher": "UTP Honduras",
    "copyright": "Copyright 2025-2026 UTP Honduras",
    "category": "Utility",
    "shortDescription": "Editor de impresion de fotos en lote",
    "longDescription": "Imprime+ es un editor de impresion de imagenes que permite disenar layouts de fotos, ajustar margenes, agregar titulos y enviar a imprimir directamente.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
